# === OBBLIGATORIO: genera con: python -c "import secrets; print(secrets.token_hex(32))" ===
SECRET_KEY=cambia-con-valore-casuale-sicuro

# === OBBLIGATORIO: genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" ===
FERNET_KEY=cambia-con-fernet-key

# === PostgreSQL (Railway genera DATABASE_URL automaticamente) ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === (opzionale) ore job notturno (default: 3) ===
SCHEDULER_HOUR=3
SCHEDULER_MINUTE=0
